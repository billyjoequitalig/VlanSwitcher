@page
@model VLAN_Switching.Pages.UserManagementModel
@{
}
<!--//Page content//-->
<div class="content pt-3 px-3 px-lg-6 d-flex flex-column-fluid">
    <div class="container-fluid px-0">
        <div class="row">
            <div class="table-responsive table-card table-nowrap">
                <table class="table table-striped table-bordered text-center">
                    <thead>
                        <tr>
                            <th style="border: 1px solid black;">ID Number</th>
                            <th style="border: 1px solid black;">NTLogin</th>
                            <th style="border: 1px solid black;">Full Name</th>
                            <th style="border: 1px solid black;">Port</th>
                            <th style="border: 1px solid black;">Campaign Name</th>
                            <th style="border: 1px solid black;">Role</th>
                            <th style="border: 1px solid black;">Status</th>
                            <th style="border: 1px solid black;">Action</th>
                            @* <th class="text-end">Action</th> *@
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.IdNumber</td>
                                <td>@user.NTlogin</td>
                                <td>@user.FullName</td>
                                <td>@user.SwitchPort?.PortName</td>
                                <td>@user.Campaign?.Name</td>
                                <td>@user.Role?.Role</td>
                                <td>@user.Status?.Status</td>
                                <td>
                                    @* <form method="post">
                                        <input type="hidden" name="UserId" value="@user.Id" />
                                        <button type="submit" asp-page-handler="Delete" class="btn btn-danger d-block w-100">Delete</button>
                                    
                                    </form> *@
                                    <form method="post" asp-page-handler="Delete"
                                          onsubmit="return confirm('Are you sure you want to delete this item?');">
                                        <input type="hidden" name="UserId" value="@user.Id" />
                                        <button type="submit" class="btn btn-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<!--//Page content End//-->


