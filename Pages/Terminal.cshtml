@page
@model VLAN_Switching.Pages.TerminalModel
@{
    ViewData["Title"] = "SSH Terminal";
}

<<form method="post" asp-page-handler="SwitchVlan">
    <div class="container min-vh-100 d-flex align-items-center justify-content-center">
        <div class="container-fluid col-md-8 col-lg-6">
            <div class="card mb-3 shadow-lg">
                <div class="card-body py-5">
                    <h3 class="text-center mb-4">SSH Terminal</h3>
                    @* <div class="row mb-3">
                        <label class="col-md-4 col-form-label text-md-end">Host Name/IP</label>
                        <div class="col-md-5">
                            <input asp-for="SshConfig.Host" class="form-control" placeholder="Enter SSH host" required />
                        </div>
                    </div> *@
                    <div class="row mb-3">
                        <label class="col-md-4 col-form-label text-md-end">Switch IP</label>
                        <div class="col-md-5">
                            <input asp-for="Host" class="form-control" placeholder="Enter Switch IP" required />
                        </div>
                    </div>
                    @if (ViewData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger mb-3">
                            <strong>Error:</strong> @ViewData["ErrorMessage"]
                        </div>
                    }
                    @if (ViewData["Result"] != null)
                    {
                        <div class="alert alert-info mb-3">
                            <strong>Result:</strong> @ViewData["Result"]
                        </div>
                    }
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">Connect</button>
                    </div>
                </div>
            </div>
            <div class="col-md-12 d-flex justify-content-center">
                <div class="card shadow-lg p-4 me-md-3" style="min-width: 350px; max-width: 500px; border-radius: 1rem; background: #fff;">
                    <h2 class="text-center mb-4" style="font-family: 'Hanken Grotesk', sans-serif;">Campaign Details</h2>
                    <div class="row mb-3">
                        <div class="col-6 text-end fw-semibold text-secondary">Hostname / IP:</div>
                        <div class="col-6 text-start">1.1.2.2</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6 text-end fw-semibold text-secondary">Current VLAN ID:</div>
                        <div class="col-6 text-start">123</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6 text-end fw-semibold text-secondary">Current VLAN Port:</div>
                        <div class="col-6 text-start">Fa0/28</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6 text-end fw-semibold text-secondary">VLAN Campaign:</div>
                        <div class="col-6 text-start">Marketing</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6 text-end fw-semibold text-secondary">Assigned User:</div>
                        <div class="col-6 text-start">Jane Doe</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6 text-end fw-semibold text-secondary">Status</div>
                        <div class="col-6 text-start text-success">Success</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/xterm@4.19.0/lib/xterm.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    @* <script>
        let connection;
        const terminal = document.getElementById('terminal');

        function appendToTerminal(text) {
            terminal.innerText += text + "\n";
            terminal.scrollTop = terminal.scrollHeight; // Scroll to bottom
        }

        document.getElementById('connectBtn').addEventListener('click', async () => {
            const username = document.getElementById('sshUsername').value;
            const password = document.getElementById('sshPassword').value;
            const ip = document.getElementById('IP').value;
            // const ip = prompt("Enter the IP address of the switch:");

            if (!ip || !username || !password) {
                alert("Please provide IP, username and password.");
                return;
            }

            connection = new signalR.HubConnectionBuilder()
                .withUrl("/terminalHub")
                .build();

            connection.on("ReceiveOutput", (output) => {
                appendToTerminal(output);
            });

            try {
                await connection.start();
                appendToTerminal("[Connecting]");

                // Call your server hub Connect method with IP, username, password
                await connection.invoke("Connect", ip, username, password);
            } catch (err) {
                appendToTerminal("[Connection error: " + err.toString() + "]");
            }
        });

        // Optional: send user input to SSH shell (you can implement a better input handler)
        // For example, listen for keyboard input in the terminal div or an input box
    </script> *@
}
